APP_ENV=development
PROJECT_ROOT=.
DEFAULT_PAIR_ID=pair_001_baby_and_mom__good_luck
INPUT_PAIR_ROOT=data/02_work_pairs
RAW_CONTEXT_OUTPUT_DIR=data/04_outputs/raw_context_workbooks
PROJECT_CONTEXT_DUMP_DIR=data/04_outputs/project_context_dumps
LOG_LEVEL=INFO

# --- AI-assisted standardization (optional) ---
# All financial-document processing stays local unless explicitly approved.
# If AI_PROVIDER is hosted_openai_compatible, AI_DATA_APPROVAL MUST be set to
# hosted_approved before any API call is made; otherwise the run fails safely.
AI_ENABLED=false
AI_PROVIDER=hosted_openai_compatible
AI_API_BASE_URL=
AI_API_KEY=
AI_MODEL_NAME=
AI_TEMPERATURE=0
AI_TIMEOUT_SECONDS=120
AI_MAX_RETRIES=2
AI_MAX_INPUT_CHARS_PER_REQUEST=12000
# Token budgeting (layered on top of the character cap):
#   AI_MAX_INPUT_TOKENS_PER_REQUEST -> oversized requests are rejected before any
#     network call (input tokens estimated conservatively at ~4 chars/token).
#   AI_MAX_OUTPUT_TOKENS            -> sent to the provider as max_tokens so
#     free/limited tiers stay bounded.
AI_MAX_INPUT_TOKENS_PER_REQUEST=3000
AI_MAX_OUTPUT_TOKENS=1024
AI_DATA_APPROVAL=local_only

TYPE_LABELS_PATH=config/type_labels.json

STANDARDIZED_OUTPUT_DIR=data/04_outputs/standardized_workbooks
REFERENCE_PROFILE_OUTPUT_DIR=data/04_outputs/reference_profiles

# --- Formalization stage (deterministic two-ledger formalization) ---
# The formalization stage is deterministic by default. AI is OPTIONAL and is
# only ever used in a token-controlled way. It can NEVER receive whole ledgers.
# AI_FORMALIZATION_MODE must stay 'off' unless you explicitly opt in.
#   off                  -> no model is ever called (default, safe)
#   layout_only          -> AI may profile column layout from a tiny sample
#   repair_failed_rows   -> AI may repair only the specific failed rows sent to it
#   group_unknown_labels -> AI may map only deterministically-unclassified rows
#                           ("Unknown") to a predefined canonical label, or return
#                           UnknownNeedsReview. It can never invent a new label.
# Activating AI still requires the global AI gate (AI_ENABLED + hosted approval).
FORMALIZED_OUTPUT_DIR=data/04_outputs/formalized_workbooks
AI_FORMALIZATION_MODE=off
AI_MAX_LAYOUT_SAMPLE_LINES=40
AI_MAX_FAILED_ROWS_PER_REQUEST=25
AI_MAX_AI_PAGES_PER_LEDGER=3
AI_FORMALIZATION_CACHE_ENABLED=true
AI_FORMALIZATION_CACHE_DIR=data/04_outputs/formalization_ai_cache

# --- Reconciliation AI arbitration (optional) ---
# Deterministic matching runs first. AI is called ONLY for unresolved/ambiguous
# clusters and may make final match decisions only after deterministic post-validation.
# Requires the global AI gate (AI_ENABLED + hosted approval when applicable).
AI_RECONCILIATION_ENABLED=false
AI_RECONCILIATION_MODE=off
#   off         -> no reconciliation AI (default, deterministic-only final matching)
#   arbitrate   -> AI arbitration for unresolved deterministic cases
AI_RECON_MAX_INPUT_TOKENS_PER_REQUEST=3000
AI_RECON_MAX_OUTPUT_TOKENS=1024
AI_RECON_MAX_CANDIDATES_PER_PACKET=12
AI_RECON_AMOUNT_TOLERANCE=0.01
AI_RECON_DATE_TOLERANCE_DAYS=7
AI_RECON_MIN_CONFIDENCE=0.75
AI_RECON_CACHE_ENABLED=true
AI_RECON_CACHE_DIR=data/04_outputs/reconciliation_ai_cache
AI_RECON_MAX_BATCHES=50
AI_RECON_REVIEW_ON_VALIDATION_FAILURE=true
# Legacy Master_Match_Table sheet (off by default; Match_Evidence is primary).
RECON_INCLUDE_MASTER_MATCH_TABLE=false
